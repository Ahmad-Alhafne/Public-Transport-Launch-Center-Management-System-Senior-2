{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "TripService": "http://tripservice:8080",
    "RouteService": "http://routeservice:8080",
    "BookingService": "http://bookingservice:8080",
    "AuthService": "http://authservice:8080",
    "ComplaintService": "http://complaintservice:8080",
    "NotificationService": "http://notificationservice:8080",
    "VehicleService": "http://vehicleservice:8080"
  },
"JwtOptions": {
  "SecretKey": "THIS_IS_A_LONG_SHARED_SECRET_KEY_123456789",
  "Issuer": "DepartureCenter",
  "Audience": "DepartureCenterUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "route-route": {
        "ClusterId": "route-cluster",
        "Match": {
          "Path": "/api/route/{**catch-all}"
        }
      },
      "trip-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/trip/{**catch-all}"
        }
      },
      "driver-profile-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/driver/{**catch-all}"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        }
      },
      "complaint-route": {
        "ClusterId": "complaint-cluster",
        "Match": {
          "Path": "/api/complaint/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        }
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": {
          "Path": "/api/vehicle/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authservice:8080/"
          }
        }
      },
      "route-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://routeservice:8080/"
          }
        }
      },
      "trip-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://tripservice:8080/"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://bookingservice:8080/"
          }
        }
      },
      "complaint-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://complaintservice:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notificationservice:8080/"
          }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://vehicleservice:8080/"
          }
        }
      }
    }
  }
}