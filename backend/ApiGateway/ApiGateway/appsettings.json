{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "TripService": "http://tripservice:8080",
    "RouteService": "http://routeservice:8080",
    "BookingService": "http://bookingservice:8080",
    "AuthService": "http://authservice:8080",
    "ComplaintService": "http://complaintservice:8080",
    "NotificationService": "http://notificationservice:8080",
    "PaymentService": "http://paymentservice:8080",
    "LiveTrackingService": "http://livetrackingservice:8080",
    "VehicleService": "http://vehicleservice:8080",
    "AuditService": "http://auditservice:8080",
    "OrganizerService": "http://organizerservice:8080"
  },
"JwtOptions": {
  "SecretKey": "THIS_IS_A_LONG_SHARED_SECRET_KEY_123456789",
  "Issuer": "DepartureCenter",
  "Audience": "DepartureCenterUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-root-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth"
        }
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-root-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users"
        }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "route-root-route": {
        "ClusterId": "route-cluster",
        "Match": {
          "Path": "/api/route"
        }
      },
      "route-route": {
        "ClusterId": "route-cluster",
        "Match": {
          "Path": "/api/route/{**catch-all}"
        }
      },
      "trip-root-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/trip"
        }
      },
      "trip-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/trip/{**catch-all}"
        }
      },
      "driver-profile-root-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/driver"
        }
      },
      "driver-profile-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/driver/{**catch-all}"
        }
      },
      "emergency-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/emergency/{**catch-all}"
        }
      },
      "emergency-root-route": {
        "ClusterId": "trip-cluster",
        "Match": {
          "Path": "/api/emergency"
        }
      },
      "booking-route": {
        "ClusterId": "booking-cluster",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        }
      },
      "complaint-route": {
        "ClusterId": "complaint-cluster",
        "Match": {
          "Path": "/api/complaint/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        }
      },
      "driver-tracking-route": {
        "ClusterId": "live-tracking-cluster",
        "Match": {
          "Path": "/api/driver/tracking/{**catch-all}"
        }
      },
      "vehicle-route": {
        "ClusterId": "vehicle-cluster",
        "Match": {
          "Path": "/api/vehicle/{**catch-all}"
        }
      }
      ,
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": {
          "Path": "/api/audit/{**catch-all}"
        }
      }
      ,
      "live-tracking-route": {
        "ClusterId": "live-tracking-cluster",
        "Match": {
          "Path": "/api/tracking/{**catch-all}"
        }
      }
      ,
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      }
      ,
      "payment-root-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payments"
        }
      }
      ,
      "live-tracking-hub-route": {
        "ClusterId": "live-tracking-cluster",
        "Match": {
          "Path": "/api/hubs/live-tracking/{**catch-all}"
        }
        ,
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "queue-route": {
        "ClusterId": "organizer-cluster",
        "Match": {
          "Path": "/api/queue/{**catch-all}"
        }
      },
      "queue-root-route": {
        "ClusterId": "organizer-cluster",
        "Match": {
          "Path": "/api/queue"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://authservice:8080/"
          }
        }
      },
      "route-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://routeservice:8080/"
          }
        }
      },
      "trip-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://tripservice:8080/"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://bookingservice:8080/"
          }
        }
      },
      "complaint-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://complaintservice:8080/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notificationservice:8080/"
          }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://auditservice:8080/"
          }
        }
      },
      "vehicle-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://vehicleservice:8080/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://paymentservice:8080/"
          }
        }
      },
      "live-tracking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://livetrackingservice:8080/"
          }
        }
      },
      "organizer-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://organizerservice:8080/"
          }
        }
      }
    }
  }
}